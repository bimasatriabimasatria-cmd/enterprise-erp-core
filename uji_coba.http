Content-Type: application/json

{ "sku": "RAW-PAKU", "name": "Paku Baja", "price": 500, "stock": 0 }
###
POST http://localhost:3000/api/items
Authorization: Bearer {{token}}
Content-Type: application/json

{ "sku": "FG-MEJA", "name": "Meja Jati Premium", "price": 500000, "stock": 0 }

