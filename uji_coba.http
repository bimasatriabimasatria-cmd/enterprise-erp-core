# Salin "ID" miliknya.

GET http://localhost:3000/api/hr/employees
Authorization: Bearer {{token}}


### ==========================================
### TAHAP 33: SIMULASI ANDI TERLAMBAT (ABSEN MASUK)
### ==========================================
# Ganti 'TEMPEL_ID_ANDI_DI_SINI' dengan ID Andi.
# Ceritanya Andi datang jam 10 Pagi (Format T10:30:00Z).
# Sistem harus mendeteksi statusnya otomatis menjadi "late".

POST http://localhost:3000/api/attendance/clock-in
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "employee_id": "219e321a-4a43-4e47-88ee-efe2012b24e2",
    "time": "2026-05-29T10:30:00Z"
}


### ==========================================
### TAHAP 34: SIMULASI ANDI PULANG KERJA (CLOCK OUT)
### ==========================================
# Di sore hari jam 17:00, Andi melakukan absen pulang.

POST http://localhost:3000/api/attendance/clock-out
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "employee_id": "219e321a-4a43-4e47-88ee-efe2012b24e2",
    "time": "2026-05-29T17:00:00Z"
}


### ==========================================
### TAHAP 35: HRD MELIHAT REKAP ABSENSI
### ==========================================
# Klik ini untuk melihat bukti bahwa sistem berhasil mencatat Andi "late" 
# dan merekam durasi kerjanya hari itu.

GET http://localhost:3000/api/attendance
Authorization: Bearer {{token}}

### ==========================================
### TAHAP 36: BUAT 2 LOKASI GUDANG
### ==========================================
# Kita buat Gudang Jakarta dan Gudang Bekasi

POST http://localhost:3000/api/warehouses
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "code": "GDG-JKT",
    "name": "Gudang Pusat Jakarta",
    "location": "Jl. Sudirman, Jakarta"
}

### (Klik Send Request pada blok di atas, lalu blok di bawah ini)

POST http://localhost:3000/api/warehouses
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "code": "GDG-BKS",
    "name": "Gudang Cabang Bekasi",
    "location": "Kawasan Industri, Bekasi"
}


### ==========================================
### TAHAP 37: CEK ID GUDANG & ID BARANG
### ==========================================
# Klik untuk mendapatkan ID Gudang Jakarta dan ID Gudang Bekasi
GET http://localhost:3000/api/warehouses
Authorization: Bearer {{token}}

### (Ambil ID Barang Laptop/Mouse dari sini jika Anda lupa)
GET http://localhost:3000/api/items
Authorization: Bearer {{token}}


### ==========================================
### TAHAP 38: MASUKKAN STOK AWAL KE GUDANG JAKARTA
### ==========================================
# Ganti ID Gudang dengan ID Gudang Jakarta, dan Item ID dengan ID Laptop/Mouse
# Ceritanya kita meletakkan 50 unit barang di Jakarta

POST http://localhost:3000/api/warehouses/inventory
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "warehouse_id": "4b643521-a2c3-443a-9907-9560f7a9d287",
    "item_id": "4f425d55-c900-4f8a-92f6-43fcf9acd711",
    "quantity": 50
}


### ==========================================
### TAHAP 39: LAKUKAN MUTASI (TRANSFER) KE BEKASI
### ==========================================
# Hari ini kita mengirim 20 unit dari Jakarta ke Cabang Bekasi!

POST http://localhost:3000/api/warehouses/transfer
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "reference": "TRF-2026-001",
    "source_id": "4b643521-a2c3-443a-9907-9560f7a9d287",
    "destination_id": "556e9ab6-018a-4dad-82e8-380da01593bc",
    "item_id": "4f425d55-c900-4f8a-92f6-43fcf9acd711",
    "quantity": 20
}


### ==========================================
### TAHAP 40: BUKTIKAN PERGERAKAN STOK
### ==========================================
# Lihat laporannya. Anda akan melihat barang tersebut sekarang terpecah:
# 30 unit di Jakarta, dan 20 unit di Bekasi!

GET http://localhost:3000/api/warehouses/inventory
Authorization: Bearer {{token}}

### ==========================================
### TAHAP 41: JOKO (STAF) MENGAJUKAN PERSETUJUAN
### ==========================================
# Pastikan {{tokenJoko}} adalah token milik Joko (Role: staff)
# Joko ingin membeli mesin pabrik seharga 1 Miliar (PO-MESIN-001)

POST http://localhost:3000/api/workflow/request
Authorization: Bearer {{tokenJoko}}
Content-Type: application/json

{
    "document_type": "PurchaseOrder",
    "document_id": "PO-MESIN-001",
    "notes": "Pak, kita butuh mesin baru seharga 1 Miliar untuk pabrik Bekasi."
}


### ==========================================
### TAHAP 42: JOKO MENCOBA MELIHAT DAFTAR PERSETUJUAN (GAGAL)
### ==========================================
# Joko iseng mencoba melihat antrean persetujuan manajer.
# Sistem harus menolak dengan pesan "403 Forbidden".

GET http://localhost:3000/api/workflow/pending
Authorization: Bearer {{tokenJoko}}


### ==========================================
### TAHAP 43: BUDI (DIREKTUR) MELIHAT ANTREAN
### ==========================================
# Sekarang kita pakai {{token}} milik Budi (Role: admin).
# Budi melihat ada pengajuan dari Joko. Salin "ID" approval tersebut!

GET http://localhost:3000/api/workflow/pending
Authorization: Bearer {{token}}


### ==========================================
### TAHAP 44: BUDI (DIREKTUR) MENYETUJUI PENGAJUAN
### ==========================================
# Ganti 'TEMPEL_ID_APPROVAL_DI_SINI' dengan ID dari Tahap 43.
# Budi menekan tombol Approve dan memberikan catatan.

POST http://localhost:3000/api/workflow/0fe6a253-9140-4641-a4de-9dc03432357b/process
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "status": "approved",
    "notes": "Baik, segera proses pembeliannya. Anggaran sudah disiapkan."
}

