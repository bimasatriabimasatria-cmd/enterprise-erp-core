### ==========================================
### TAHAP 3: TAMBAH BARANG GUDANG
### ==========================================
POST http://localhost:3000/api/items
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "sku": "LAP-ASUS-001",
    "name": "Laptop Asus ROG 2026",
    "description": "Laptop Gaming Super Cepat",
    "price": 15000000,
    "stock": 10
}


### ==========================================
### TAHAP 4: CEK DAFTAR BARANG
### ==========================================
# Klik ini untuk melihat daftar barang sekaligus menyalin "ID" barang tersebut.
GET http://localhost:3000/api/items
Authorization: Bearer {{token}}


### ==========================================
### TAHAP 5: UJI OTOMATISASI FAKTUR PENJUALAN
### ==========================================
# Hapus teks 'TEMPEL_ID_BARANG_DI_SINI' dan ganti dengan ID barang dari Tahap 4.
# Kita akan mencoba membeli 2 buah laptop.

POST http://localhost:3000/api/invoices
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "invoice_number": "INV-2026-001",
    "customer_name": "Toko Maju Jaya",
    "date": "2026-05-29",
    "lines": [
        {
            "item_id": "4f425d55-c900-4f8a-92f6-43fcf9acd711",
            "quantity": 2
        }
    ]
}


### ==========================================
### TAHAP 6: CEK STOK TERAKHIR (PEMBUKTIAN)
### ==========================================
# Klik ini untuk membuktikan bahwa stok laptop berkurang otomatis.
GET http://localhost:3000/api/items
Authorization: Bearer {{token}}

### ==========================================
### TAHAP 7: BUAT PESANAN PEMBELIAN (PO)
### ==========================================
# Ganti 'TEMPEL_ID_BARANG_DI_SINI' dengan ID barang yang sama seperti tahap sebelumnya.
# Kita memesan 20 laptop dengan harga modal 12.000.000

POST http://localhost:3000/api/pos
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "po_number": "PO-2026-001",
    "supplier_name": "Pabrik Asus Taiwan",
    "date": "2026-05-30",
    "lines": [
        {
            "item_id": "4f425d55-c900-4f8a-92f6-43fcf9acd711",
            "quantity": 20,
            "unit_price": 12000000
        }
    ]
}


### ==========================================
### TAHAP 8: CEK DAFTAR PO UNTUK AMBIL ID
### ==========================================
# Klik ini untuk melihat daftar PO yang baru dibuat.
# Salin "ID" milik PO tersebut (Bukan ID barang, tapi ID PO-nya).

GET http://localhost:3000/api/pos
Authorization: Bearer {{token}}


### ==========================================
### TAHAP 9: TERIMA BARANG DI GUDANG
### ==========================================
# Ganti teks 'TEMPEL_ID_PO_DI_SINI' di URL bawah ini dengan ID dari Tahap 8.
# Jika sukses di-klik, sistem akan memproses penambahan stok.

POST http://localhost:3000/api/pos/ce08f5a6-2250-4009-91a4-ecd8fb3e8acd/receive
Authorization: Bearer {{token}}
Content-Type: application/json


### ==========================================
### TAHAP 10: CEK STOK (PEMBUKTIAN)
### ==========================================
# Stok Anda sekarang harus menjadi 28!
GET http://localhost:3000/api/items
Authorization: Bearer {{token}}

### ==========================================
### TAHAP 11: BUAT BUKU AKUNTANSI SYARAT PENJUALAN
### ==========================================
# Klik Send Request pada DUA akun di bawah ini agar ERP mengenali kode akun standar.

# Buat Akun Piutang (Tagihan ke Pelanggan)
POST http://localhost:3000/api/accounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "account_code": "1120",
    "account_name": "Piutang Usaha",
    "account_type": "asset"
}

###

# Buat Akun Pendapatan
POST http://localhost:3000/api/accounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "account_code": "4100",
    "account_name": "Pendapatan Penjualan",
    "account_type": "revenue"
}


### ==========================================
### TAHAP 12: UJI COBA KEAJAIBAN ERP (AUTO-JOURNAL)
### ==========================================
# Ambil ID Barang (Laptop) dari tahap-tahap sebelumnya, ganti di bawah ini.
# Kita jual 3 buah laptop ke PT Makmur Sejahtera.

POST http://localhost:3000/api/invoices
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "invoice_number": "INV-2026-002",
    "customer_name": "PT Makmur Sejahtera",
    "date": "2026-05-31",
    "lines": [
        {
            "item_id": "4f425d55-c900-4f8a-92f6-43fcf9acd711",
            "quantity": 3
        }
    ]
}


### ==========================================
### TAHAP 13: BUKTIKAN BUKU BESAR (FINANCE) TERISI OTOMATIS
### ==========================================
# Lihat jurnal keuangan paling atas. Anda akan melihat jurnal baru 
# tanpa ada satupun staf akunting yang mengetiknya!

GET http://localhost:3000/api/journals
Authorization: Bearer {{token}}

### ==========================================
### TAHAP 14: CARI ID FAKTUR YANG BELUM LUNAS
### ==========================================
# Klik Send Request untuk melihat daftar Faktur.
# Cari Faktur "INV-2026-002" yang statusnya masih "unpaid".
# Salin "ID" faktur tersebut.

GET http://localhost:3000/api/invoices
Authorization: Bearer {{token}}


### ==========================================
### TAHAP 15: TERIMA PEMBAYARAN DARI PELANGGAN
### ==========================================
# Hapus teks 'TEMPEL_ID_FAKTUR_DI_SINI' dan ganti dengan ID dari Tahap 14.
# Kita akan mencairkan Rp 45.000.000 ke rekening bank.

POST http://localhost:3000/api/payments/receive
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "receipt_number": "PAY-2026-001",
    "invoice_id": "a8109b73-ff36-43ce-945e-c8dd20446995",
    "payment_date": "2026-06-01"
}


### ==========================================
### TAHAP 16: LIHAT BUKU BESAR TERBARU (PEMBUKTIAN)
### ==========================================
# Cek jurnal keuangan Anda. Anda akan melihat jurnal baru 
# di mana uang di Kas Bank BCA bertambah (Debit) dan Piutang berkurang (Kredit).

GET http://localhost:3000/api/journals
Authorization: Bearer {{token}}

### ==========================================
### TAHAP 17: BUAT BUKU AKUNTANSI BIAYA GAJI
### ==========================================
# Sebelum menggaji, kita wajib membuat buku "Beban Gaji" (Tipe Expense) di akuntansi.

POST http://localhost:3000/api/accounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "account_code": "5100",
    "account_name": "Beban Gaji & Upah",
    "account_type": "expense"
}


### ==========================================
### TAHAP 18: TAMBAH KARYAWAN BARU
### ==========================================
# Mendaftarkan Andi sebagai Manajer dengan Gaji Pokok Rp 10.000.000

POST http://localhost:3000/api/hr/employees
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nik": "EMP-2026-001",
    "name": "Andi Manajer",
    "position": "General Manager",
    "basic_salary": 10000000,
    "hire_date": "2026-01-01"
}


### ==========================================
### TAHAP 19: CEK DAFTAR KARYAWAN
### ==========================================
# Klik untuk melihat daftar karyawan. 
# Salin "ID" milik Andi Manajer.

GET http://localhost:3000/api/hr/employees
Authorization: Bearer {{token}}


### ==========================================
### TAHAP 20: CAIRKAN GAJI (PROCESS PAYROLL)
### ==========================================
# Ganti 'TEMPEL_ID_KARYAWAN_DI_SINI' dengan ID dari Tahap 19.
# Kita beri bonus (allowance) 2 juta, dan potongan telat (deduction) 500 ribu.

POST http://localhost:3000/api/hr/payroll
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "employee_id": "219e321a-4a43-4e47-88ee-efe2012b24e2",
    "period": "2026-05",
    "allowances": 20000000,
    "deductions": 500000,
    "payment_date": "2026-05-29"
}


### ==========================================
### TAHAP 21: BUKTIKAN UANG BANK BERKURANG
### ==========================================
# Lihat Jurnal Akuntansi. Akan ada jurnal otomatis baru yang mencatat:
# Beban Gaji (Debit) bertambah, dan Kas Bank (Kredit) berkurang 
# karena uangnya sudah ditransfer ke Andi!

GET http://localhost:3000/api/journals
Authorization: Bearer {{token}}

### ==========================================
### TAHAP 22: TAMBAH CALON PELANGGAN (LEAD)
### ==========================================
# Tim Sales baru saja menelepon Bapak Budi dari PT Inovasi Maju.

POST http://localhost:3000/api/crm/leads
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "name": "Bapak Budi",
    "company": "PT Inovasi Maju",
    "email": "budi@inovasi.com",
    "phone": "08123456789"
}


### ==========================================
### TAHAP 23: CEK DAFTAR LEAD
### ==========================================
# Klik untuk melihat prospek kita.
# Salin "ID" milik PT Inovasi Maju.

GET http://localhost:3000/api/crm/leads
Authorization: Bearer {{token}}


### ==========================================
### TAHAP 24: KONVERSI LEAD JADI CUSTOMER
### ==========================================
# Ganti 'TEMPEL_ID_LEAD_DI_SINI' dengan ID dari Tahap 23.
# Ceritanya PT Inovasi Maju setuju untuk beli produk kita!

POST http://localhost:3000/api/crm/leads/980d4203-0df2-4432-9382-34906dc065ea/convert
Authorization: Bearer {{token}}
Content-Type: application/json


### ==========================================
### TAHAP 25: BUKTIKAN DI MASTER PELANGGAN
### ==========================================
# Cek Daftar Customer Resmi. PT Inovasi Maju sekarang otomatis 
# sudah masuk ke tabel Customer siap untuk dibuatkan Faktur!

GET http://localhost:3000/api/crm/customers
Authorization: Bearer {{token}}

### ==========================================
### TAHAP 26: LIHAT LAPORAN LABA RUGI (DASHBOARD DIREKTUR)
### ==========================================
# Klik Send Request untuk melihat performa finansial perusahaan Anda.
# Sistem akan otomatis menghitung semua faktur penjualan yang sudah dibuat 
# dan menguranginya dengan semua gaji karyawan yang sudah dibayar!

GET http://localhost:3000/api/reports/income-statement
Authorization: Bearer {{token}}

